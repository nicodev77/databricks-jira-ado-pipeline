{
  "datasets": [
    {
      "name": "226b4e58",
      "displayName": "releases",
      "queryLines": [
        "SELECT \r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    story_point_total,\r\n",
        "    amount_of_work_items,\r\n",
        "    missing_story_points,\r\n",
        "    last_update\r\n",
        "FROM releases\r\n",
        "ORDER BY release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "ab1e95b6",
      "displayName": "releases_progress",
      "queryLines": [
        "SELECT \r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    CASE state\r\n",
        "        WHEN 'unstarted'         THEN 'Not Started'\r\n",
        "        WHEN 'in_progress'       THEN 'In Progress'\r\n",
        "        WHEN 'blocked'           THEN 'Blocked'\r\n",
        "        WHEN 'pending_review'    THEN 'Pending Review'\r\n",
        "        WHEN 'merged_internally' THEN 'Merged Internally'\r\n",
        "        WHEN 'merged_to_client'  THEN 'Merged to Client'\r\n",
        "        WHEN 'user_testing'      THEN 'User Testing'\r\n",
        "        WHEN 'done'              THEN 'Done'\r\n",
        "        WHEN 'removed'           THEN 'Removed'\r\n",
        "        ELSE state\r\n",
        "    END AS state,\r\n",
        "    count\r\n",
        "FROM (\r\n",
        "    SELECT release_name, 'unstarted' AS state, unstarted AS count FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'in_progress', in_progress FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'blocked', blocked FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'pending_review', pending_review FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'merged_internally', merged_internally FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'merged_to_client', merged_to_client FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'user_testing', user_testing FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'done', done FROM releases\r\n",
        "    UNION ALL SELECT release_name, 'removed', removed FROM releases\r\n",
        ")\r\n",
        "ORDER BY release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "51785077",
      "displayName": "mapped_user_stories",
      "queryLines": [
        "SELECT\r\n",
        "    jira_id,\r\n",
        "    jira_name,\r\n",
        "    COALESCE(ado_status, jira_status) AS status,\r\n",
        "    jira_assignee,\r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type\r\n",
        "FROM mapped_user_stories\r\n",
        "CROSS JOIN LATERAL (SELECT explode(jira_fix_versions) AS release_name)\r\n",
        "ORDER BY release_name, jira_id"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "47ca56b5",
      "displayName": "releases_velocity",
      "queryLines": [
        "SELECT\r\n",
        "    release_name,\r\n",
        "    story_point_total AS velocity,\r\n",
        "    amount_of_work_items,\r\n",
        "    missing_story_points,\r\n",
        "    CASE\r\n",
        "        WHEN missing_story_points > 0 THEN 'Unreliable'\r\n",
        "        ELSE 'Reliable'\r\n",
        "    END AS reliability\r\n",
        "FROM releases\r\n",
        "ORDER BY release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "d1372dbb",
      "displayName": "releases_counters",
      "queryLines": [
        "SELECT\r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    total_work,\r\n",
        "    done,\r\n",
        "    removed,\r\n",
        "    (total_work - done - removed) AS outstanding\r\n",
        "FROM releases\r\n",
        "ORDER BY release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "17b40ef6",
      "displayName": "load_distribution",
      "queryLines": [
        "SELECT \r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    SUM(story_point_total) AS total_story_points,\r\n",
        "    COUNT(*) AS total_releases,\r\n",
        "    SUM(missing_story_points) AS total_missing\r\n",
        "FROM releases\r\n",
        "GROUP BY release_type\r\n",
        "ORDER BY total_story_points DESC"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "bba46b9e",
      "displayName": "velocity_reliable",
      "queryLines": [
        "SELECT\r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    CASE \r\n",
        "        WHEN CONTAINS(release_name, '-') \r\n",
        "            THEN SPLIT(release_name, '-')[1]\r\n",
        "        ELSE release_name\r\n",
        "    END AS version,\r\n",
        "    CASE \r\n",
        "        WHEN missing_story_points = 0 AND story_point_total IS NOT NULL \r\n",
        "            THEN story_point_total\r\n",
        "        ELSE missing_story_points\r\n",
        "    END AS velocity,\r\n",
        "    missing_story_points,\r\n",
        "    CASE \r\n",
        "        WHEN missing_story_points = 0 AND story_point_total IS NOT NULL \r\n",
        "            THEN 'Reliable'\r\n",
        "        ELSE 'Has Nulls'\r\n",
        "    END AS status,\r\n",
        "    CASE\r\n",
        "        WHEN CONTAINS(release_name, '-')\r\n",
        "        THEN LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[0] AS STRING), 5, '0') || '.' ||\r\n",
        "             LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[1] AS STRING), 5, '0') || '.' ||\r\n",
        "             LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[2] AS STRING), 5, '0')\r\n",
        "        ELSE '00000.00000.00000'\r\n",
        "    END AS sort_key\r\n",
        "FROM releases\r\n",
        "ORDER BY\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1),\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[0] AS INT) ELSE NULL END,\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[1] AS INT) ELSE NULL END,\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[2] AS INT) ELSE NULL END,\r\n",
        "    release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "e20fdd31",
      "displayName": "velocity_nulls",
      "queryLines": [
        "SELECT\r\n",
        "    release_name,\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1) AS release_type,\r\n",
        "    amount_of_work_items,\r\n",
        "    missing_story_points,\r\n",
        "    ROUND(missing_story_points / amount_of_work_items * 100, 1) AS missing_pct\r\n",
        "FROM releases\r\n",
        "WHERE missing_story_points > 0\r\n",
        "ORDER BY missing_story_points DESC"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    },
    {
      "name": "0f067c33",
