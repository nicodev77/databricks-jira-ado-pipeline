        "        WHEN missing_story_points = 0 AND story_point_total IS NOT NULL \r\n",
        "            THEN 'Reliable'\r\n",
        "        ELSE 'Has Nulls'\r\n",
        "    END AS status,\r\n",
        "    CASE\r\n",
        "        WHEN CONTAINS(release_name, '-')\r\n",
        "        THEN LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[0] AS STRING), 5, '0') || '.' ||\r\n",
        "             LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[1] AS STRING), 5, '0') || '.' ||\r\n",
        "             LPAD(CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[2] AS STRING), 5, '0')\r\n",
        "        ELSE '00000.00000.00000'\r\n",
        "    END AS sort_key\r\n",
        "FROM releases\r\n",
        "ORDER BY\r\n",
        "    REGEXP_EXTRACT(release_name, '^([A-Za-z&]+)', 1),\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[0] AS INT) ELSE NULL END,\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[1] AS INT) ELSE NULL END,\r\n",
        "    CASE WHEN CONTAINS(release_name, '-') THEN CAST(SPLIT(SPLIT(release_name, '-')[1], '\\\\.')[2] AS INT) ELSE NULL END,\r\n",
        "    release_name"
      ],
      "catalog": "enterprise_local_dev",
      "schema": "gold_client"
    }
